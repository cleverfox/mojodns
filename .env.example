# --- shared secrets -------------------------------------------------------
POSTGRES_PASSWORD=change-me-postgres
PDNS_API_KEY=change-me-pdns-api-key
SESSION_SECRET=change-me-long-random-string
BOOTSTRAP_ADMIN_PASSWORD=change-me-admin

# --- DNS topology ---------------------------------------------------------
# Catalog zone consumed by the NSD secondaries (trailing dot required)
CATALOG_ZONE=catalog.mojodns.
# Public NSD secondaries: receive NOTIFY and are allowed to AXFR
ALSO_NOTIFY_IPS="192.0.2.10:53, 192.0.2.11:53"
ALLOW_AXFR_IPS="192.0.2.10/32,192.0.2.11/32"
# Default SOA primary nameserver + hostmaster for new zones
DEFAULT_SOA_NS=ns1.example.net.
DEFAULT_SOA_MAIL=hostmaster.example.net.
# Default NS set offered when creating a zone (comma separated, trailing dots)
DEFAULT_NAMESERVERS=ns1.example.net.,ns2.example.net.

# --- ports exposed on the host --------------------------------------------
WEB_PORT=8000
# rootless podman/docker cannot bind ports <1024; use 53 only on a rootful
# production host (or raise net.ipv4.ip_unprivileged_port_start)
DNS_PORT=1053

# --- TSIG for zone transfers (recommended over the public internet) --------
# generate once:  podman exec mojodns-py-pdns-1 pdnsutil --config-dir=/tmp/pdns \
#                   generate-tsig-key mojodns-xfr hmac-sha256
# When TSIG_KEY is set the panel puts TSIG-ALLOW-AXFR on every zone; with
# ALLOW_AXFR_IPS="" transfers are possible ONLY with a valid signature.
# TSIG_SECRET is needed by the *slaves* (and the test slave container).
TSIG_KEY=
TSIG_ALGO=hmac-sha256
TSIG_SECRET=
